app/pmb-backend/yarn-error.log
app/pmb-backend/storage/*.key
app/pmb-backend/storage/framework/cache/*
app/pmb-backend/storage/framework/sessions/*
app/pmb-backend/storage/framework/testing/*
app/pmb-backend/storage/framework/views/*
app/pmb-backend/storage/logs/*

# SQLite db
app/pmb-backend/database/database.sqlite
app/pmb-backend/database/*.sqlite-journal

# JS / npm
app/pmb-frontend/node_modules/
app/pmb-frontend/.env
app/pmb-frontend/.env.local
app/pmb-frontend/.cache/
